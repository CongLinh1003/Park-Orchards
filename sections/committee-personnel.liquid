{%- comment -%}
  Committee Personnel — Card grid with vCard download
  Each card pulls from club_person metaobjects filtered by group = committee-personnel.
  Click triggers .vcf download for native "Add Contact" on mobile.
{%- endcomment -%}

{%- liquid
  assign heading     = section.settings.heading
  assign bg_color    = section.settings.bg_color
  assign text_color  = section.settings.text_color
  assign accent      = section.settings.accent_color
  assign card_bg     = section.settings.card_bg
  assign cols_d      = section.settings.columns_desktop
  assign cols_t      = section.settings.columns_tablet
  assign cols_m      = section.settings.columns_mobile
  assign group_handle = section.settings.group_handle
-%}

<section
  id="committee-{{ section.id }}"
  class="committee-section"
  style="
    --cp-bg: {{ bg_color }};
    --cp-text: {{ text_color }};
    --cp-accent: {{ accent }};
    --cp-card-bg: {{ card_bg }};
    --cp-cols-d: {{ cols_d }};
    --cp-cols-t: {{ cols_t }};
    --cp-cols-m: {{ cols_m }};
  "
>
  <div class="committee__inner">

    {%- if heading != blank -%}
      <h2 class="committee__heading">{{ heading }}</h2>
    {%- endif -%}

    <div class="committee__grid">
      {%- assign all_people = shop.metaobjects.club_person.values -%}
      {%- assign found = 0 -%}

      {%- for person in all_people -%}
        {%- assign person_group = person.group.value -%}
        {%- assign person_group_handle = person_group.handle | default: person_group.system.handle -%}

        {%- if person_group_handle == group_handle -%}
          {%- assign found = found | plus: 1 -%}
          {%- assign p_name  = person.full_name.value | default: person.display_name -%}
          {%- assign p_role  = person.role_title.value -%}
          {%- assign p_phone = person.phone.value -%}
          {%- assign p_email = person.email.value -%}
          {%- assign p_photo = person.photo.value -%}
          {%- assign p_order = person.sort_order.value | default: 999 -%}

          <div
            class="committee__card"
            role="button"
            tabindex="0"
            aria-label="Save contact for {{ p_name | escape }}"
            data-name="{{ p_name | escape }}"
            data-role="{{ p_role | escape }}"
            data-phone="{{ p_phone | escape }}"
            data-email="{{ p_email | escape }}"
            data-org="Park Orchards Football & Netball Club"
            {%- if p_photo != blank -%}
              data-photo="{{ p_photo | image_url: width: 400 }}"
            {%- endif -%}
            onclick="downloadVCard(this)"
            onkeydown="if(event.key==='Enter')downloadVCard(this)"
          >
            <div class="committee__card-photo">
              {%- if p_photo != blank -%}
                <img
                  src="{{ p_photo | image_url: width: 400 }}"
                  alt="{{ p_name | escape }}"
                  width="200"
                  height="200"
                  loading="lazy"
                  class="committee__card-img"
                >
              {%- else -%}
                <div class="committee__card-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="48" height="48"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>
                </div>
              {%- endif -%}
            </div>

            <div class="committee__card-body">
              <h3 class="committee__card-name">{{ p_name }}</h3>
              {%- if p_role != blank -%}
                <span class="committee__card-role">{{ p_role }}</span>
              {%- endif -%}
              {%- if p_phone != blank -%}
                <span class="committee__card-phone">{{ p_phone }}</span>
              {%- endif -%}
              {%- if p_email != blank -%}
                <span class="committee__card-email">{{ p_email }}</span>
              {%- endif -%}
            </div>

            <div class="committee__card-action">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
              <span>Save Contact</span>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if found == 0 -%}
        <p class="committee__empty">No committee personnel found.</p>
      {%- endif -%}
    </div>

  </div>
</section>

<script>
  function downloadVCard(el) {
    var name  = el.getAttribute('data-name') || '';
    var role  = el.getAttribute('data-role') || '';
    var phone = el.getAttribute('data-phone') || '';
    var email = el.getAttribute('data-email') || '';
    var org   = el.getAttribute('data-org') || '';
    var photo = el.getAttribute('data-photo') || '';

    // Split name into parts
    var parts = name.trim().split(/\s+/);
    var firstName = parts[0] || '';
    var lastName = parts.slice(1).join(' ') || '';

    var lines = [
      'BEGIN:VCARD',
      'VERSION:3.0',
      'FN:' + name,
      'N:' + lastName + ';' + firstName + ';;;',
      'ORG:' + org,
      'TITLE:' + role
    ];

    if (phone) {
      // Clean phone for TEL field
      lines.push('TEL;TYPE=WORK,VOICE:' + phone);
    }
    if (email) {
      lines.push('EMAIL;TYPE=WORK:' + email);
    }
    if (photo) {
      lines.push('URL;TYPE=PHOTO:' + photo);
    }

    lines.push('END:VCARD');

    var vcfContent = lines.join('\r\n');
    var blob = new Blob([vcfContent], { type: 'text/vcard;charset=utf-8' });
    var url = URL.createObjectURL(blob);

    var a = document.createElement('a');
    a.href = url;
    a.download = name.replace(/\s+/g, '_') + '.vcf';
    document.body.appendChild(a);
    a.click();

    setTimeout(function() {
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }, 100);
  }
</script>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Anek+Gurmukhi:wght@400;600;700;800&display=swap');

  #committee-{{ section.id }} {
    background: var(--cp-bg);
    color: var(--cp-text);
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    font-family: 'Anek Gurmukhi', system-ui, sans-serif;
  }

  #committee-{{ section.id }} .committee__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 3vw, 3rem);
  }

  /* ─── Heading ─── */
  #committee-{{ section.id }} .committee__heading {
    font-family: 'Antonio', 'Oswald', 'Impact', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
    margin: 0 0 clamp(1.5rem, 3vw, 2.5rem);
    color: var(--cp-text);
  }

  /* ─── Grid ─── */
  #committee-{{ section.id }} .committee__grid {
    display: grid;
    grid-template-columns: repeat(var(--cp-cols-m), 1fr);
    gap: clamp(0.8rem, 2vw, 1.5rem);
  }

  @media (min-width: 750px) {
    #committee-{{ section.id }} .committee__grid {
      grid-template-columns: repeat(var(--cp-cols-t), 1fr);
    }
  }

  @media (min-width: 990px) {
    #committee-{{ section.id }} .committee__grid {
      grid-template-columns: repeat(var(--cp-cols-d), 1fr);
    }
  }

  /* ─── Card ─── */
  #committee-{{ section.id }} .committee__card {
    background: var(--cp-card-bg);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 6px;
    padding: clamp(1.2rem, 2vw, 1.8rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    cursor: pointer;
    transition: box-shadow 0.3s ease, transform 0.25s ease;
    position: relative;
  }

  #committee-{{ section.id }} .committee__card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    transform: translateY(-3px);
  }

  #committee-{{ section.id }} .committee__card:active {
    transform: translateY(0);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  /* ─── Photo ─── */
  #committee-{{ section.id }} .committee__card-photo {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  #committee-{{ section.id }} .committee__card-img {
    width: clamp(100px, 40%, 160px);
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }

  #committee-{{ section.id }} .committee__card-placeholder {
    width: clamp(100px, 40%, 160px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #bbb;
  }

  /* ─── Body ─── */
  #committee-{{ section.id }} .committee__card-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    width: 100%;
  }

  #committee-{{ section.id }} .committee__card-name {
    font-family: 'Antonio', 'Oswald', 'Impact', sans-serif;
    font-weight: 700;
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.15;
    margin: 0;
    color: #1a1a1a;
  }

  #committee-{{ section.id }} .committee__card-role {
    font-weight: 600;
    font-size: clamp(0.75rem, 1vw, 0.85rem);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--cp-accent);
    margin-bottom: 0.4rem;
  }

  #committee-{{ section.id }} .committee__card-phone,
  #committee-{{ section.id }} .committee__card-email {
    font-size: clamp(0.78rem, 1vw, 0.9rem);
    color: #777;
    line-height: 1.5;
    word-break: break-all;
  }

  /* ─── Save Contact action ─── */
  #committee-{{ section.id }} .committee__card-action {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.8rem;
    padding-top: 0.6rem;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    width: 100%;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--cp-accent);
    transition: opacity 0.2s;
  }

  #committee-{{ section.id }} .committee__card:hover .committee__card-action {
    opacity: 0.8;
  }

  /* ─── Empty message ─── */
  #committee-{{ section.id }} .committee__empty {
    grid-column: 1 / -1;
    text-align: center;
    opacity: 0.5;
    font-style: italic;
    padding: 2rem 0;
  }
{% endstyle %}

{% schema %}
{
  "name": "Committee Personnel",
  "tag": "section",
  "class": "committee-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Committee Personnel"
    },
    {
      "type": "text",
      "id": "group_handle",
      "label": "People Group Handle",
      "info": "Must match the handle of the club_people_group entry, e.g. committee-personnel",
      "default": "committee-personnel"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#b0121b"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Committee Personnel"
    }
  ]
}
{% endschema %}
