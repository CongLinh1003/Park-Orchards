            {%- endcase -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>

  {%- comment -%} ── BOTTOM CONTACT BAR ── {%- endcomment -%}
  {%- if section.settings.address != blank or section.settings.phone != blank or section.settings.email != blank or section.settings.hours != blank -%}
    <div class="scb__contact-bar">
      <div class="scb__contact-bar-inner">
        {%- if section.settings.address != blank -%}
          <div class="scb-contact-item">
            <div class="scb-contact-icon">
              <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>
            </div>
            <div class="scb-contact-body">
              <span class="scb-contact-label">Address</span>
              <span class="scb-contact-value">{{ section.settings.address }}</span>
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.phone != blank -%}
          <div class="scb-contact-item">
            <div class="scb-contact-icon">
              <svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            </div>
            <div class="scb-contact-body">
              <span class="scb-contact-label">Phone</span>
              <span class="scb-contact-value"><a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone }}</a></span>
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.email != blank -%}
          <div class="scb-contact-item">
            <div class="scb-contact-icon">
              <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            </div>
            <div class="scb-contact-body">
              <span class="scb-contact-label">Email</span>
              <span class="scb-contact-value"><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></span>
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.hours != blank -%}
          <div class="scb-contact-item">
            <div class="scb-contact-icon">
              <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
            </div>
            <div class="scb-contact-body">
              <span class="scb-contact-label">Hours</span>
              <span class="scb-contact-value">{{ section.settings.hours }}</span>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

</section>

<script>
(function() {
  var css = [
    'form[data-testid="form"]{display:flex!important;flex-direction:row!important;flex-wrap:wrap!important;gap:8px!important;align-items:flex-start!important}',
    'form[data-testid="form"]>*{width:100%!important;box-sizing:border-box!important;flex-shrink:0!important}',
    'form[data-testid="form"]>*:has(#first_name),form[data-testid="form"]>*:has(#last_name){flex:1 1 calc(50% - 4px)!important;width:auto!important;min-width:0!important}'
  ].join('');

  function inject() {
    var embed = document.querySelector('shopify-forms-embed');
    if (!embed) return false;
    var root = embed.shadowRoot;
    if (!root) return false;
    if (!root.querySelector('#scb-name-fix')) {
      var s = document.createElement('style');
      s.id = 'scb-name-fix';
      s.textContent = css;
      root.appendChild(s);
    }
    return true;
  }

  var n = 0, t = setInterval(function() {
    if (inject() || ++n > 75) clearInterval(t);
  }, 200);
})();
</script>

