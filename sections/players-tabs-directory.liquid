{%- paginate shop.metaobjects.player_profile.values by 1000 -%}
{%- liquid
  assign accent = section.settings.accent_color
  assign sport_handle = section.settings.sport_handle
  assign division_handle = section.settings.division_handle

  assign players_all = shop.metaobjects.player_profile.values
  if section.settings.sort_mode == 'sort_order'
    assign players_all = players_all | sort: 'sort_order'
  elsif section.settings.sort_mode == 'jersey_number'
    assign players_all = players_all | sort: 'jersey_number'
  else
    assign players_all = players_all | sort: 'full_name'
  endif

  assign limit = section.settings.players_limit
  assign shown = 0
-%}

<section
  class="po-players-directory po-players-directory--{{ section.id }}"
  style="
    --po-accent: {{ accent }};
    --po-cols-desktop: {{ section.settings.columns_desktop }};
    --po-cols-tablet: {{ section.settings.columns_tablet }};
    --po-cols-mobile: {{ section.settings.columns_mobile }};
  "
  id="PlayersDirectory-{{ section.id }}"
>
  <div class="po-players-directory__inner page-width">
    {% if section.settings.show_heading and section.settings.heading != blank %}
      <h2 class="po-players-directory__heading">
        {{ section.settings.heading | escape }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <div class="po-players-directory__subheading">{{ section.settings.subheading }}</div>
    {% endif %}

    <div class="po-players-directory__grid">
      {%- for player in players_all -%}
        {%- liquid
          if limit != blank and limit > 0 and shown >= limit
            break
          endif

          assign team_obj = player.team.value
          if team_obj == blank
            continue
          endif

          comment
            Shopify Liquid cannot reliably resolve nested metaobject references
            (player → team → sport). Instead, filter by team handle which encodes
            division-sport-grade, e.g. "men-football-seniors", "women-netball-u19".
            We split the handle to compare exact segments and avoid substring
            false matches (e.g. "men" in "women").
          endcomment

          assign team_h = team_obj.system.handle | default: ''
          assign handle_parts = team_h | split: '-'

          comment
            Handle format: {division}-{sport}-{grade} or {division}-{sport}-{grade1}-{grade2}
            Examples: men-football-seniors, women-netball-u19, men-football-under-19
            Part 0 = division, Part 1 = sport, Part 2+ = grade
          endcomment

          assign h_division = handle_parts[0] | default: ''
          assign h_sport = handle_parts[1] | default: ''

          comment
            Only filter by sport and division — grade is intentionally ignored
            so that all players (seniors, reserves, under-19, etc.) appear together.
          endcomment

          if h_sport != sport_handle
            continue
          endif
          if h_division != division_handle
            continue
          endif

          assign shown = shown | plus: 1
        -%}

        {% render 'player-card',
          player: player,
          accent_color: accent,
          show_jersey_number: section.settings.show_jersey_number,
          show_position: section.settings.show_position,
          show_team_name: section.settings.show_team_name,
          open_in_new_tab: section.settings.open_in_new_tab,
          placeholder_image: section.settings.placeholder_image
        %}
      {%- endfor -%}
    </div>

    {% if shown == 0 %}
      <div class="po-players-directory__no-results">
        {{ section.settings.empty_message }}
      </div>
    {% endif %}
  </div>

  <style>
    .po-players-directory--{{ section.id }}{
      --po-accent: {{ accent }};
      padding: clamp(28px, 4vw, 56px) 0;
      background: {{ section.settings.background_color }};
    }

    .po-players-directory--{{ section.id }} .po-players-directory__heading{
      margin: 0 0 16px;
      text-align:center;
      color: var(--po-accent);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .28em;
      font-size: clamp(40px, 7vw, 92px);
      line-height: 1.05;
    }

    .po-players-directory--{{ section.id }} .po-players-directory__subheading{
      text-align:center;
      max-width: 900px;
      margin: 0 auto 22px;
    }

    .po-players-directory--{{ section.id }} .po-players-directory__grid{
      display:flex;
      flex-wrap:wrap;
      gap: 14px;
      justify-content: center;
      margin-top: 10px;
    }

    .po-players-directory--{{ section.id }} .po-player-card{
      position: relative;
      display:block;
      text-decoration:none;
      color: inherit;
      background: #fff;
      border: 1px solid rgba(0,0,0,.08);
      overflow:hidden;
      aspect-ratio: 3 / 4;
      width: calc((100% - 14px * (var(--po-cols-mobile) - 1)) / var(--po-cols-mobile));
    }

    @media (min-width: 750px){
      .po-players-directory--{{ section.id }} .po-player-card{
        width: calc((100% - 14px * (var(--po-cols-tablet) - 1)) / var(--po-cols-tablet));
      }
    }

    @media (min-width: 990px){
      .po-players-directory--{{ section.id }} .po-player-card{
        width: calc((100% - 14px * (var(--po-cols-desktop) - 1)) / var(--po-cols-desktop));
      }
    }

    .po-players-directory--{{ section.id }} .po-player-card__media{
      position:absolute;
      inset:0;
    }

    .po-players-directory--{{ section.id }} .po-player-card__bg-texture {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      background-image:url('https://cdn.shopify.com/s/files/1/0970/7290/6603/files/Player_Jersey.jpg?v=1776758413');
      background-repeat: no-repeat;
      background-position: 50% 20%;
      background-size: 60%;
      background-color: white;
    }

    .po-players-directory--{{ section.id }} .po-player-card__jersey-info {
      position: absolute;
      top: 24%;
      left: 51%;
      transform: translateX(-50%);
      width: 55%;
      text-align: center;
      color: white;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      text-transform: uppercase;
      font-family: 'Antonio', sans-serif;
    }

    .po-players-directory--{{ section.id }} .po-player-card__jersey-number {
      font-weight: 800;
      line-height: 0.9;
      font-size: clamp(3rem, 4vw, 4rem);
      margin-bottom: 12px;
    }

    .po-players-directory--{{ section.id }} .po-player-card__jersey-nickname {
      font-size: clamp(12px, 1.2vw, 16px);
      font-weight: 700;
      line-height: 1.1;
    }

    .po-players-directory--{{ section.id }} .po-player-card__img,
    .po-players-directory--{{ section.id }} .po-player-card__placeholder{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
      background: transparent;
      position: relative;
      z-index: 2;
    }

    .po-players-directory--{{ section.id }} .po-player-card__overlay{
      position:absolute;
      inset:0;
      background: linear-gradient(to top, rgba(176,18,27,.85) 0%, rgba(176,18,27,.5) 20%, rgba(176,18,27,0) 45%);
      z-index: 3;
    }

    .po-players-directory--{{ section.id }} .po-player-card__text{
      position:absolute;
      left: 14px;
      right: 14px;
      bottom: 14px;
      z-index: 4;
      color:#fff;
      text-transform: uppercase;
    }

    .po-players-directory--{{ section.id }} .po-player-card__team{
      font-weight: 800;
      opacity: .92;
      letter-spacing: .06em;
      font-size: 12px;
      margin-bottom: 6px;
    }

    .po-players-directory--{{ section.id }} .po-player-card__name{
      font-weight: 900;
      letter-spacing: .05em;
      font-size: clamp(18px, 2.1vw, 26px);
      line-height: 1.05;
    }

    .po-players-directory--{{ section.id }} .po-player-card__pos{
      margin-top: 6px;
      font-weight: 800;
      letter-spacing: .06em;
      font-size: 13px;
      opacity: .95;
    }

    .po-players-directory--{{ section.id }} .po-players-directory__no-results{
      text-align:center;
      margin-top: 18px;
      opacity: .8;
      width: 100%;
    }
  </style>

{%- endpaginate -%}

  {% schema %}
  {
    "name": "Players Directory",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_heading",
        "label": "Show large heading",
        "default": true
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "PLAYERS"
      },
      {
        "type": "richtext",
        "id": "subheading",
        "label": "Subheading",
        "default": "<p>&nbsp;</p>"
      },
      {
        "type": "select",
        "id": "sport_handle",
        "label": "Sport (club_sport handle)",
        "default": "football",
        "options": [
          { "value": "football", "label": "Football" },
          { "value": "netball", "label": "Netball" }
        ]
      },
      {
        "type": "select",
        "id": "division_handle",
        "label": "Division (club_division handle)",
        "default": "men",
        "options": [
          { "value": "men", "label": "Men" },
          { "value": "women", "label": "Women" }
        ]
      },
      {
        "type": "select",
        "id": "sort_mode",
        "label": "Sort players by",
        "default": "sort_order",
        "options": [
          { "value": "sort_order", "label": "Sort Order" },
          { "value": "jersey_number", "label": "Jersey Number" },
          { "value": "full_name", "label": "Full Name" }
        ]
      },
      {
        "type": "range",
        "id": "players_limit",
        "label": "Players limit (0 = no limit)",
        "min": 0,
        "max": 200,
        "step": 2,
        "default": 0
      },
      {
        "type": "checkbox",
        "id": "show_jersey_number",
        "label": "Show jersey number",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_position",
        "label": "Show role/position",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_team_name",
        "label": "Show team name",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "open_in_new_tab",
        "label": "Open PlayHQ link in new tab",
        "default": true
      },
      {
        "type": "image_picker",
        "id": "placeholder_image",
        "label": "Placeholder image (when player has no profile photo)"
      },
      {
        "type": "color",
        "id": "accent_color",
        "label": "Accent color",
        "default": "#b0121b"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background color",
        "default": "#ffffff"
      },
      {
        "type": "range",
        "id": "columns_desktop",
        "label": "Grid columns (desktop)",
        "min": 2,
        "max": 6,
        "step": 1,
        "default": 5
      },
      {
        "type": "range",
        "id": "columns_tablet",
        "label": "Grid columns (tablet)",
        "min": 2,
        "max": 5,
        "step": 1,
        "default": 3
      },
      {
        "type": "range",
        "id": "columns_mobile",
        "label": "Grid columns (mobile)",
        "min": 1,
        "max": 3,
        "step": 1,
        "default": 2
      },
      {
        "type": "text",
        "id": "empty_message",
        "label": "Empty message",
        "default": "No players found."
      }
    ],
    "blocks": [],
    "presets": [
      {
        "name": "Players Directory"
      }
    ]
  }
  {% endschema %}
</section>