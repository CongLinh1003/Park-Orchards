{%- comment -%}
  Benefits Grid — e.g. "Membership Benefits"
  Configurable grid: columns + gap
  Each benefit = block with icon dot + title + description
{%- endcomment -%}

{%- liquid
  assign subtitle  = section.settings.subtitle
  assign heading   = section.settings.heading
  assign accent    = section.settings.accent_color
  assign bg_color  = section.settings.background_color
  assign text_col  = section.settings.text_color
  assign cols_d    = section.settings.columns_desktop
  assign cols_t    = section.settings.columns_tablet
  assign cols_m    = section.settings.columns_mobile
-%}

<section
  class="po-benefits po-benefits--{{ section.id }}"
  style="
    --pob-accent: {{ accent }};
    --pob-bg: {{ bg_color }};
    --pob-text: {{ text_col }};
    --pob-cols-d: {{ cols_d }};
    --pob-cols-t: {{ cols_t }};
    --pob-cols-m: {{ cols_m }};
  "
>
  <div class="po-benefits__inner">

    {%- comment -%} ═══ HEADING ═══ {%- endcomment -%}
    {%- if subtitle != blank or heading != blank -%}
      <div class="po-benefits__header">
        {%- if subtitle != blank -%}
          <span class="po-benefits__subtitle">{{ subtitle }}</span>
        {%- endif -%}
        {%- if heading != blank -%}
          <h2 class="po-benefits__heading">{{ heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ═══ CARDS GRID ═══ {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="po-benefits__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'benefit_card' -%}
            <div class="po-benefits__card" {{ block.shopify_attributes }}>
              <div class="po-benefits__card-top">
                <span class="po-benefits__card-dot" aria-hidden="true"></span>
                {%- if block.settings.title != blank -%}
                  <h3 class="po-benefits__card-title">{{ block.settings.title }}</h3>
                {%- endif -%}
              </div>
              {%- if block.settings.description != blank -%}
                <div class="po-benefits__card-desc">{{ block.settings.description }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Anek+Gurmukhi:wght@400;600;700;800&display=swap');

  .po-benefits--{{ section.id }} {
    background: var(--pob-bg);
    color: var(--pob-text);
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    font-family: 'Antonio', 'Oswald', sans-serif;
  }

  .po-benefits--{{ section.id }} .po-benefits__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 3vw, 3rem);
  }

  /* ─── Header ─── */
  .po-benefits--{{ section.id }} .po-benefits__header {
    text-align: center;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .po-benefits--{{ section.id }} .po-benefits__subtitle {
    display: block;
    font-weight: 800;
    font-size: clamp(0.85rem, 1.2vw, 1rem);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.15rem;
    color: var(--pob-text);
    font-family: 'Anek Gurmukhi', sans-serif;
  }

  .po-benefits--{{ section.id }} .po-benefits__heading {
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 3.5rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.05;
    margin: 0;
    color: var(--pob-accent);
  }

  /* ─── Grid ─── */
  .po-benefits--{{ section.id }} .po-benefits__grid {
    display: grid;
    grid-template-columns: repeat(var(--pob-cols-m), 1fr);
    gap: clamp(0.8rem, 1.5vw, 1.2rem);
  }

  @media (min-width: 750px) {
    .po-benefits--{{ section.id }} .po-benefits__grid {
      grid-template-columns: repeat(var(--pob-cols-t), 1fr);
    }
  }

  @media (min-width: 990px) {
    .po-benefits--{{ section.id }} .po-benefits__grid {
      grid-template-columns: repeat(var(--pob-cols-d), 1fr);
    }
  }

  /* ─── Card ─── */
  .po-benefits--{{ section.id }} .po-benefits__card {
    border: 2px solid var(--pob-accent);
    padding: clamp(1rem, 2vw, 1.5rem);
    background: var(--pob-bg);
  }

  .po-benefits--{{ section.id }} .po-benefits__card-top {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.6rem;
  }

  .po-benefits--{{ section.id }} .po-benefits__card-dot {
    width: 22px;
    height: 22px;
    min-width: 22px;
    border-radius: 50%;
    background: var(--pob-accent);
  }

  .po-benefits--{{ section.id }} .po-benefits__card-title {
    font-weight: 900;
    font-size: clamp(0.9rem, 1.3vw, 1.1rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.15;
    margin: 0;
    color: var(--pob-text);
    font-family: 'Anek Gurmukhi', sans-serif;
  }

  .po-benefits--{{ section.id }} .po-benefits__card-desc {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: clamp(0.82rem, 1vw, 0.92rem);
    line-height: 1.55;
    opacity: 0.8;
    color: var(--pob-text);
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 749px) {
    .po-benefits--{{ section.id }} .po-benefits__card-dot {
      width: 18px;
      height: 18px;
      min-width: 18px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Benefits Grid",
  "tag": "section",
  "class": "po-benefits-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Memberships"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Benefits"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (border & dot)",
      "default": "#b0121b"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    }
  ],
  "blocks": [
    {
      "type": "benefit_card",
      "name": "Benefit Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Describe this benefit here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits Grid",
      "blocks": [
        { "type": "benefit_card", "settings": { "title": "Access to Home Games", "description": "<p>Attend all home games and be part of the action.</p>" } },
        { "type": "benefit_card", "settings": { "title": "Club Communication", "description": "<p>Stay updated with all club news and developments</p>" } },
        { "type": "benefit_card", "settings": { "title": "Exclusive Club Events", "description": "<p>Invitations to special events, including our annual Domenerians Luncheon,...</p>" } },
        { "type": "benefit_card", "settings": { "title": "Member Perks", "description": "<p>Enjoy discounts and special offers at club events, and receive exclusive merchandise.</p>" } }
      ]
    }
  ]
}
{% endschema %}
