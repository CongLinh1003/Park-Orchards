{%- comment -%}
  Sponsorship Packages Section
  Data source: sponsorship_package metaobjects
  Sorted by sort_order field, filtered to active == true only.

  Metaobject fields:
    package_name  — text label shown in banner badge
    price         — e.g. $30,000+GST
    min_term      — e.g. 2 YEAR MINIMUM
    inclusions    — rich_text_field (ordered list of benefits)
    sort_order    — integer (lower = appears first)
    active        — boolean (false = hidden)
{%- endcomment -%}

{%- liquid
  assign subhead        = section.settings.subhead
  assign heading        = section.settings.heading
  assign enquiry_label  = section.settings.enquiry_label
  assign enquiry_url    = section.settings.enquiry_url
  assign bg_color       = section.settings.bg_color
  assign heading_color  = section.settings.heading_color
  assign accent_color   = section.settings.accent_color
  assign all_packages   = shop.metaobjects.sponsorship_package.values
-%}

<section
  id="sp-packages-{{ section.id }}"
  class="sp-packages"
  style="
    --sp-pkg-bg: {{ bg_color }};
    --sp-pkg-accent: {{ accent_color }};
    --sp-pkg-accent-rgb: {{ accent_color | color_to_rgb | remove: 'rgb(' | remove: ')' }};
    --sp-pkg-heading: {{ heading_color }};
  "
>
  <div class="sp-packages__inner">

    <div class="sp-packages__header">
      {%- if subhead != blank -%}
        <span class="sp-packages__subhead">{{ subhead }}</span>
      {%- endif -%}
      {%- if heading != blank -%}
        <h2 class="sp-packages__heading">{{ heading }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%}
      Collect active packages and sort by sort_order (ascending).
      Liquid cannot natively sort metaobject arrays by a custom field, so we
      use a selection-sort: repeatedly find the package with the lowest
      sort_order that hasn't been placed yet, append its handle to
      sorted_handles, then render in that order.
    {%- endcomment -%}

    {%- comment -%} Step 1: collect active handles + their sort_order values {%- endcomment -%}
    {%- assign active_handles = '' -%}
    {%- assign active_orders  = '' -%}
    {%- for pkg in all_packages -%}
      {%- assign is_active = pkg.active.value -%}
      {%- if is_active == true or is_active == 'true' -%}
        {%- assign active_handles = active_handles | append: pkg.system.handle | append: '|' -%}
        {%- assign pkg_order = pkg.sort_order.value | default: 999 -%}
        {%- assign active_orders  = active_orders  | append: pkg_order | append: '|' -%}
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Step 2: selection sort — build sorted_handles string {%- endcomment -%}
    {%- assign handle_arr = active_handles | split: '|' | compact -%}
    {%- assign order_arr  = active_orders  | split: '|' | compact -%}
    {%- assign sorted_handles = '' -%}
    {%- assign used_indices   = '' -%}

    {%- assign pkg_count = handle_arr.size -%}
    {%- for _pass in (1..20) -%}
      {%- if _pass > pkg_count -%}{%- break -%}{%- endif -%}
      {%- assign min_order = 99999 -%}
      {%- assign min_idx   = -1 -%}
      {%- for h in handle_arr -%}
        {%- assign idx_str = forloop.index0 | append: '|' -%}
        {%- if used_indices contains idx_str -%}{%- continue -%}{%- endif -%}
        {%- assign this_order = order_arr[forloop.index0] | plus: 0 -%}
        {%- if this_order < min_order -%}
          {%- assign min_order = this_order -%}
          {%- assign min_idx   = forloop.index0 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if min_idx >= 0 -%}
        {%- assign sorted_handles  = sorted_handles | append: handle_arr[min_idx] | append: '|' -%}
        {%- assign used_indices    = used_indices | append: min_idx | append: '|' -%}
      {%- endif -%}
    {%- endfor -%}

    {%- assign sorted_handle_arr = sorted_handles | split: '|' | compact -%}

    {%- comment -%} Step 3: build a lookup map handle → metaobject {%- endcomment -%}
    {%- comment -%} (Shopify Liquid supports shop.metaobjects[type][handle]) {%- endcomment -%}

    {%- if all_packages.size > 0 -%}
      <div class="sp-packages__slider-wrap">
        {%- comment -%} Prev arrow {%- endcomment -%}
        <button class="sp-packages__arrow sp-packages__arrow--prev" aria-label="Previous package">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>

        <div class="sp-packages__viewport">
          <div class="sp-packages__track" id="spTrack-{{ section.id }}">
            {%- for h in sorted_handle_arr -%}
              {%- assign pkg = shop.metaobjects.sponsorship_package[h] -%}
              {%- if pkg != blank -%}
                {%- assign pkg_tier     = pkg.system.display_name | default: pkg.package_name.value | remove: '#' | replace: '_', ' ' -%}
                {%- assign pkg_price    = pkg.price.value -%}
                {%- assign pkg_min_term = pkg.min_term.value -%}

                <div class="sp-packages__card">
                  {%- comment -%} Clean modern card header {%- endcomment -%}
                  <div class="sp-packages__card-header">
                    <div class="sp-packages__tier-label">{{ pkg_tier }}</div>
                    <div class="sp-packages__price-block">
                      {%- if pkg_price != blank -%}
                        <span class="sp-packages__price">{{ pkg_price }}</span>
                      {%- endif -%}
                      {%- if pkg_min_term != blank -%}
                        <span class="sp-packages__min-term">{{ pkg_min_term }}</span>
                      {%- endif -%}
                    </div>
                  </div>

                  {%- comment -%} Divider {%- endcomment -%}
                  <div class="sp-packages__divider"></div>

                  {%- comment -%} Inclusions list — render rich_text_field as HTML {%- endcomment -%}
                  <div class="sp-packages__card-body">
                    {%- unless pkg.inclusions.value == blank -%}
                      <h3 class="sp-packages__inclusions-heading">Inclusions</h3>
                      <div class="sp-packages__inclusions-list">
                        {{ pkg.inclusions | metafield_tag }}
                      </div>
                    {%- endunless -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        {%- comment -%} Next arrow {%- endcomment -%}
        <button class="sp-packages__arrow sp-packages__arrow--next" aria-label="Next package">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      {%- comment -%} Dot indicators (one per active package) {%- endcomment -%}
      <div class="sp-packages__dots" id="spDots-{{ section.id }}">
        {%- for h in sorted_handle_arr -%}
          <button class="sp-packages__dot{% if forloop.first %} is-active{% endif %}" aria-label="Go to slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Enquiry button {%- endcomment -%}
    {%- if enquiry_label != blank -%}
      <div class="sp-packages__cta">
        <a
          href="{{ enquiry_url | default: '#' }}"
          class="sp-packages__enquiry-btn"
        >
          {{ enquiry_label }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

  /* ═══════════════════════════════════════════
     SPONSORSHIP PACKAGES — Modern redesign
  ═══════════════════════════════════════════ */

  #sp-packages-{{ section.id }} {
    background: linear-gradient(160deg, #0a0000 0%, #2a0000 50%, #0d0d0d 100%);
    padding: clamp(3.5rem, 7vw, 6rem) 0;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    position: relative;
    overflow: hidden;
  }

  /* Ambient glow effects */
  #sp-packages-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(var(--sp-pkg-accent-rgb), 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.02) 0%, transparent 50%);
    pointer-events: none;
  }

  #sp-packages-{{ section.id }} .sp-packages__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem);
    position: relative;
    z-index: 1;
  }

  /* ─── Header ─── */
  #sp-packages-{{ section.id }} .sp-packages__header {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  #sp-packages-{{ section.id }} .sp-packages__subhead {
    display: inline-block;
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--sp-pkg-accent, #c0182d);
    margin: 0 0 0.75rem;
    padding: 0.35rem 1rem;
    border: 1px solid rgba(var(--sp-pkg-accent-rgb), 0.3);
    border-radius: 100px;
    background: rgba(var(--sp-pkg-accent-rgb), 0.08);
  }

  #sp-packages-{{ section.id }} .sp-packages__heading {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: #fff;
    margin: 0;
    line-height: 1.1;
  }

  /* ─── Slider wrap ─── */
  #sp-packages-{{ section.id }} .sp-packages__slider-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 900px;
    margin: 0 auto;
  }

  /* ─── Viewport & Track ─── */
  #sp-packages-{{ section.id }} .sp-packages__viewport {
    flex: 1;
    overflow: hidden;
    padding: 1.5rem 0.5rem;
    margin: -1.5rem -0.5rem;
  }

  #sp-packages-{{ section.id }} .sp-packages__track {
    display: flex;
    gap: 2rem;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  /* ─── Card ─── */
  #sp-packages-{{ section.id }} .sp-packages__card {
    flex: 0 0 100%;
    min-width: 0;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.3s ease,
                box-shadow 0.4s ease;
  }

  #sp-packages-{{ section.id }} .sp-packages__card:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--sp-pkg-accent-rgb), 0.3);
    box-shadow:
      0 20px 60px -15px rgba(0, 0, 0, 0.5),
      0 0 40px -10px rgba(var(--sp-pkg-accent-rgb), 0.12);
  }

  /* Accent top bar */
  #sp-packages-{{ section.id }} .sp-packages__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--sp-pkg-accent, #c0182d), transparent);
    border-radius: 20px 20px 0 0;
  }

  /* ─── Card header ─── */
  #sp-packages-{{ section.id }} .sp-packages__card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: clamp(1.5rem, 3vw, 2.25rem) clamp(1.5rem, 3vw, 2.5rem) 0;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ─── Tier label (clean, modern — replaces the old sticker badge) ─── */
  #sp-packages-{{ section.id }} .sp-packages__tier-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: #fff;
  }

  /* ─── Price block ─── */
  #sp-packages-{{ section.id }} .sp-packages__price-block {
    text-align: right;
    flex-shrink: 0;
  }

  #sp-packages-{{ section.id }} .sp-packages__price {
    display: block;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 900;
    color: var(--sp-pkg-accent, #c0182d);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  #sp-packages-{{ section.id }} .sp-packages__min-term {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.35rem;
  }

  /* ─── Divider ─── */
  #sp-packages-{{ section.id }} .sp-packages__divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    margin: clamp(1rem, 2vw, 1.5rem) clamp(1.5rem, 3vw, 2.5rem);
  }

  /* ─── Card body (inclusions) ─── */
  #sp-packages-{{ section.id }} .sp-packages__card-body {
    padding: 0 clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 3vw, 2.5rem);
    flex: 1;
  }

  #sp-packages-{{ section.id }} .sp-packages__inclusions-heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--sp-pkg-accent, #c0182d);
    margin: 0 0 1rem;
  }

  #sp-packages-{{ section.id }} .sp-packages__inclusions-list {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    columns: 2;
    column-gap: 2rem;
  }

  #sp-packages-{{ section.id }} .sp-packages__inclusions-list ol,
  #sp-packages-{{ section.id }} .sp-packages__inclusions-list ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #sp-packages-{{ section.id }} .sp-packages__inclusions-list li {
    margin-bottom: 0.5rem;
    padding-left: 1.5rem;
    position: relative;
    break-inside: avoid;
  }

  /* Check icon for list items */
  #sp-packages-{{ section.id }} .sp-packages__inclusions-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.4em;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(var(--sp-pkg-accent-rgb), 0.15);
  }

  #sp-packages-{{ section.id }} .sp-packages__inclusions-list li::after {
    content: '';
    position: absolute;
    left: 4px;
    top: calc(0.4em + 3px);
    width: 6px;
    height: 3px;
    border-left: 1.5px solid var(--sp-pkg-accent, #c0182d);
    border-bottom: 1.5px solid var(--sp-pkg-accent, #c0182d);
    transform: rotate(-45deg);
  }

  /* ─── Arrow buttons ─── */
  #sp-packages-{{ section.id }} .sp-packages__arrow {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: rgba(255, 255, 255, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  #sp-packages-{{ section.id }} .sp-packages__arrow:hover {
    background: rgba(var(--sp-pkg-accent-rgb), 0.15);
    border-color: rgba(var(--sp-pkg-accent-rgb), 0.35);
    color: #fff;
    transform: scale(1.05);
  }

  #sp-packages-{{ section.id }} .sp-packages__arrow:disabled {
    opacity: 0.2;
    cursor: not-allowed;
    transform: none;
  }

  /* ─── Dot indicators ─── */
  #sp-packages-{{ section.id }} .sp-packages__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  #sp-packages-{{ section.id }} .sp-packages__dot {
    width: 8px;
    height: 8px;
    border-radius: 100px;
    border: none;
    background: rgba(255, 255, 255, 0.15);
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  #sp-packages-{{ section.id }} .sp-packages__dot.is-active {
    background: var(--sp-pkg-accent, #c0182d);
    width: 24px;
  }

  #sp-packages-{{ section.id }} .sp-packages__dot:hover:not(.is-active) {
    background: rgba(255, 255, 255, 0.3);
  }

  /* ─── CTA / Enquiry button ─── */
  #sp-packages-{{ section.id }} .sp-packages__cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  #sp-packages-{{ section.id }} .sp-packages__enquiry-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: var(--sp-pkg-accent, #c0182d);
    color: #fff;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    border-radius: 12px;
    border: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  #sp-packages-{{ section.id }} .sp-packages__enquiry-btn:hover {
    filter: brightness(1.15);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -4px rgba(var(--sp-pkg-accent-rgb), 0.45);
  }

  #sp-packages-{{ section.id }} .sp-packages__enquiry-btn svg {
    transition: transform 0.3s ease;
  }

  #sp-packages-{{ section.id }} .sp-packages__enquiry-btn:hover svg {
    transform: translateX(3px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    #sp-packages-{{ section.id }} {
      padding: 3rem 0;
    }

    #sp-packages-{{ section.id }} .sp-packages__slider-wrap {
      gap: 0;
    }

    #sp-packages-{{ section.id }} .sp-packages__arrow {
      display: none;
    }

    #sp-packages-{{ section.id }} .sp-packages__card-header {
      flex-direction: column;
      gap: 0.75rem;
    }

    #sp-packages-{{ section.id }} .sp-packages__price-block {
      text-align: left;
    }

    #sp-packages-{{ section.id }} .sp-packages__inclusions-list {
      columns: 1;
    }
  }
{% endstyle %}

<script>
  (function () {
    var section   = document.getElementById('sp-packages-{{ section.id }}');
    if (!section) return;

    var track     = section.querySelector('.sp-packages__track');
    var cards     = section.querySelectorAll('.sp-packages__card');
    var dots      = section.querySelectorAll('.sp-packages__dot');
    var btnPrev   = section.querySelector('.sp-packages__arrow--prev');
    var btnNext   = section.querySelector('.sp-packages__arrow--next');
    var total     = cards.length;
    var current   = 0;

    function goTo(index) {
      current = (index + total) % total;
      track.style.transform = 'translateX(calc(-' + (current * 100) + '% - ' + (current * 2) + 'rem))';
      dots.forEach(function (d, i) {
        d.classList.toggle('is-active', i === current);
      });
      if (btnPrev) btnPrev.disabled = false;
      if (btnNext) btnNext.disabled = false;
    }

    if (btnPrev) btnPrev.addEventListener('click', function () { goTo(current - 1); });
    if (btnNext) btnNext.addEventListener('click', function () { goTo(current + 1); });

    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () { goTo(i); });
    });

    /* Touch / swipe */
    var startX = 0;
    var track_el = section.querySelector('.sp-packages__viewport');
    if (track_el) {
      track_el.addEventListener('touchstart', function (e) {
        startX = e.changedTouches[0].clientX;
      }, { passive: true });
      track_el.addEventListener('touchend', function (e) {
        var diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) {
          goTo(diff > 0 ? current + 1 : current - 1);
        }
      }, { passive: true });
    }

    goTo(0);
  })();
</script>

{% schema %}
{
  "name": "Sponsorship Packages",
  "tag": "section",
  "class": "sp-packages-section",
  "settings": [
    {
      "type": "text",
      "id": "subhead",
      "label": "Sub-heading",
      "default": "PARK ORCHARDS FOOTBALL NETBALL CLUB AFFILIATED EFNL"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "SPONSORSHIP PACKAGES SEASON 2025"
    },
    {
      "type": "header",
      "content": "Enquiry Button"
    },
    {
      "type": "text",
      "id": "enquiry_label",
      "label": "Button Label",
      "default": "Enquire About Sponsorship"
    },
    {
      "type": "url",
      "id": "enquiry_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0a0000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (red)",
      "default": "#c0182d"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Sponsorship Packages"
    }
  ]
}
{% endschema %}
