{%- comment -%}
  Club People Section 
  Displays all club personnel grouped by their `club_people_group`.
  For example: Committee Personnel, Support Personnel, Volunteers.
  Each card pulls from club_person metaobjects.
  Click triggers .vcf download for native "Add Contact" on mobile.
{%- endcomment -%}

{%- liquid
  assign bg_color    = section.settings.bg_color
  assign text_color  = section.settings.text_color
  assign accent      = section.settings.accent_color
  assign card_bg     = section.settings.card_bg
  assign cols_d      = section.settings.columns_desktop
  assign cols_t      = section.settings.columns_tablet
  assign cols_m      = section.settings.columns_mobile
-%}

<section
  id="club-people-{{ section.id }}"
  class="club-people-section"
  style="
    --cp-bg: {{ bg_color }};
    --cp-text: {{ text_color }};
    --cp-accent: {{ accent }};
    --cp-card-bg: {{ card_bg }};
    --cp-cols-d: {{ cols_d }};
    --cp-cols-t: {{ cols_t }};
    --cp-cols-m: {{ cols_m }};
  "
>
  <div class="club-people__inner">

    {%- comment -%} Get all people and groups {%- endcomment -%}
    {%- assign all_people = shop.metaobjects.club_person.values -%}
    {%- assign all_groups = shop.metaobjects.club_people_group.values -%}
    
    {%- assign total_found = 0 -%}

    {%- for group in all_groups -%}
      {%- assign group_handle = group.handle | default: group.system.handle -%}
      {%- assign group_name = group.name.value | default: group.display_name -%}
      
      {%- comment -%} Find people in this group {%- endcomment -%}
      {%- assign group_people = '' | split: '' -%}
      {%- assign count_in_group = 0 -%}

      {%- capture group_html -%}
        <div class="club-people__group">
          <h2 class="club-people__heading">{{ group_name }}</h2>
          <div class="club-people__grid">
            {%- for person in all_people -%}
              {%- assign p_group = person.group.value -%}
              {%- assign p_group_handle = p_group.handle | default: p_group.system.handle -%}

              {%- if p_group_handle == group_handle -%}
                {%- assign count_in_group = count_in_group | plus: 1 -%}
                {%- assign total_found = total_found | plus: 1 -%}
                
                {%- assign p_name  = person.full_name.value | default: person.display_name -%}
                {%- assign p_role  = person.role_title.value -%}
                {%- assign p_phone = person.phone.value -%}
                {%- assign p_email = person.email.value -%}
                {%- assign p_photo = person.photo.value -%}

                <div
                  class="club-people__card"
                  role="button"
                  tabindex="0"
                  aria-label="Save contact for {{ p_name | escape }}"
                  data-name="{{ p_name | escape }}"
                  data-role="{{ p_role | escape }}"
                  data-phone="{{ p_phone | escape }}"
                  data-email="{{ p_email | escape }}"
                  data-org="Park Orchards Football & Netball Club"
                  {%- if p_photo != blank -%}
                    data-photo="{{ p_photo | image_url: width: 400 }}"
                  {%- endif -%}
                  onclick="downloadVCard(this)"
                  onkeydown="if(event.key==='Enter')downloadVCard(this)"
                >
                  <div class="club-people__card-photo">
                    {%- if p_photo != blank -%}
                      <img
                        src="{{ p_photo | image_url: width: 400 }}"
                        alt="{{ p_name | escape }}"
                        width="200"
                        height="200"
                        loading="lazy"
                        class="club-people__card-img"
                      >
                    {%- else -%}
                      <div class="club-people__card-placeholder">
                        <img src="https://cdn.shopify.com/s/files/1/0898/4759/5307/files/pofnc-logo-large.png?v=1741044464" alt="Park Orchards Logo" loading="lazy" class="club-people__card-logo-placeholder">
                      </div>
                    {%- endif -%}
                  </div>

                  <div class="club-people__card-body">
                    <h3 class="club-people__card-name">{{ p_name }}</h3>
                    {%- if p_role != blank -%}
                      <span class="club-people__card-role">{{ p_role }}</span>
                    {%- endif -%}
                    {%- if p_phone != blank -%}
                      <span class="club-people__card-phone">{{ p_phone }}</span>
                    {%- endif -%}
                    {%- if p_email != blank -%}
                      <span class="club-people__card-email">{{ p_email }}</span>
                    {%- endif -%}
                  </div>

                  <div class="club-people__card-action">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                    <span>Save Contact</span>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endcapture -%}

      {%- if count_in_group > 0 -%}
        {{ group_html }}
      {%- endif -%}

    {%- endfor -%}

    {%- if total_found == 0 -%}
      <div class="club-people__empty">
        <p>No club personnel found.</p>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  function downloadVCard(el) {
    var name  = el.getAttribute('data-name') || '';
    var role  = el.getAttribute('data-role') || '';
    var phone = el.getAttribute('data-phone') || '';
    var email = el.getAttribute('data-email') || '';
    var org   = el.getAttribute('data-org') || '';
    var photo = el.getAttribute('data-photo') || '';

    // Split name into parts
    var parts = name.trim().split(/\s+/);
    var firstName = parts[0] || '';
    var lastName = parts.slice(1).join(' ') || '';

    var lines = [
      'BEGIN:VCARD',
      'VERSION:3.0',
      'FN:' + name,
      'N:' + lastName + ';' + firstName + ';;;',
      'ORG:' + org,
      'TITLE:' + role
    ];

    if (phone) {
      lines.push('TEL;TYPE=WORK,VOICE:' + phone);
    }
    if (email) {
      lines.push('EMAIL;TYPE=WORK:' + email);
    }
    if (photo) {
      lines.push('URL;TYPE=PHOTO:' + photo);
    }

    lines.push('END:VCARD');

    var vcfContent = lines.join('\r\n');
    var blob = new Blob([vcfContent], { type: 'text/vcard;charset=utf-8' });
    var url = URL.createObjectURL(blob);

    var a = document.createElement('a');
    a.href = url;
    a.download = name.replace(/\s+/g, '_') + '.vcf';
    document.body.appendChild(a);
    a.click();

    setTimeout(function() {
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }, 100);
  }
</script>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Anek+Gurmukhi:wght@400;600;700;800&display=swap');

  #club-people-{{ section.id }} {
    background: var(--cp-bg);
    color: var(--cp-text);
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    font-family: 'Anek Gurmukhi', system-ui, sans-serif;
  }

  #club-people-{{ section.id }} .club-people__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 3vw, 3rem);
  }
  
  #club-people-{{ section.id }} .club-people__group {
    margin-bottom: 4rem;
  }
  
  #club-people-{{ section.id }} .club-people__group:last-child {
    margin-bottom: 0;
  }

  /* ─── Heading ─── */
  #club-people-{{ section.id }} .club-people__heading {
    font-family: 'Antonio', 'Oswald', 'Impact', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3.5rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
    margin: 0 0 clamp(1.5rem, 3vw, 2.5rem);
    color: var(--cp-text);
  }

  /* ─── Grid ─── */
  #club-people-{{ section.id }} .club-people__grid {
    display: grid;
    grid-template-columns: repeat(var(--cp-cols-m), 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  @media (min-width: 750px) {
    #club-people-{{ section.id }} .club-people__grid {
      grid-template-columns: repeat(var(--cp-cols-t), 1fr);
    }
  }

  @media (min-width: 990px) {
    #club-people-{{ section.id }} .club-people__grid {
      grid-template-columns: repeat(var(--cp-cols-d), 1fr);
    }
  }

  /* ─── Card ─── */
  #club-people-{{ section.id }} .club-people__card {
    background: var(--cp-card-bg);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    padding: clamp(1.2rem, 2vw, 1.8rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    cursor: pointer;
    transition: box-shadow 0.3s ease, transform 0.25s ease;
    position: relative;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
  }

  #club-people-{{ section.id }} .club-people__card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    transform: translateY(-3px);
  }

  #club-people-{{ section.id }} .club-people__card:active {
    transform: translateY(0);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  /* ─── Photo ─── */
  #club-people-{{ section.id }} .club-people__card-photo {
    width: 100%;
    display: flex;
    justify-content: flex-start;
    margin-bottom: 1rem;
  }

  #club-people-{{ section.id }} .club-people__card-img {
    width: clamp(120px, 60%, 180px);
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }

  #club-people-{{ section.id }} .club-people__card-placeholder {
    width: clamp(120px, 60%, 180px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  #club-people-{{ section.id }} .club-people__card-logo-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: contain;
  }

  /* ─── Body ─── */
  #club-people-{{ section.id }} .club-people__card-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    width: 100%;
  }

  #club-people-{{ section.id }} .club-people__card-name {
    font-family: 'Antonio', 'Impact', sans-serif;
    font-weight: 800;
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.15;
    margin: 0;
    color: #1a1a1a;
  }

  #club-people-{{ section.id }} .club-people__card-role {
    font-family: 'Antonio', 'Impact', sans-serif;
    font-weight: 800;
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.15;
    color: #1a1a1a;
    margin-bottom: 0.5rem;
  }

  #club-people-{{ section.id }} .club-people__card-phone,
  #club-people-{{ section.id }} .club-people__card-email {
    font-size: clamp(0.85rem, 1vw, 0.95rem);
    color: #888;
    line-height: 1.5;
    word-break: break-all;
    font-weight: 600;
  }

  /* ─── Save Contact action ─── */
  #club-people-{{ section.id }} .club-people__card-action {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.2rem;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    width: 100%;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--cp-accent);
    transition: opacity 0.2s;
  }

  #club-people-{{ section.id }} .club-people__card:hover .club-people__card-action {
    opacity: 0.8;
  }

  /* ─── Empty message ─── */
  #club-people-{{ section.id }} .club-people__empty {
    text-align: center;
    opacity: 0.5;
    font-style: italic;
    padding: 2rem 0;
  }
{% endstyle %}

{% schema %}
{
  "name": "Club People",
  "tag": "section",
  "class": "club-people-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "This section automatically displays all people from 'club_person' metaobjects, grouped by their respective 'club_people_group'."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#b0121b"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Club People"
    }
  ]
}
{% endschema %}
