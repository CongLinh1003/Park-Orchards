{%- comment -%}
  Club Merchandise — Product List Section
  
  Self-contained section: queries a collection and displays products in
  a 4-column grid with the club's branded styling.
  - Two-line heading: subtitle + main title
  - Product cards: image, name, price, excerpt, "Add To Cart" button
  - "See More →" link at bottom right
{%- endcomment -%}

{%- liquid
  assign subtitle = section.settings.subtitle
  assign heading = section.settings.heading
  assign collection = section.settings.collection
  assign max_products = section.settings.max_products
  assign btn_label = section.settings.button_label | default: 'Add To Cart'
  assign see_more_label = section.settings.see_more_label | default: 'See More'
  assign bg_color = section.settings.bg_color
  assign card_bg = section.settings.card_bg
  assign accent = section.settings.accent_color
  assign text_color = section.settings.text_color
-%}

<section
  id="club-merch-{{ section.id }}"
  class="club-merch"
  style="
    --cm-bg: {{ bg_color }};
    --cm-card: {{ card_bg }};
    --cm-accent: {{ accent }};
    --cm-text: {{ text_color }};
  "
>
  {%- comment -%} ── Heading ── {%- endcomment -%}
  <div class="club-merch__header">
    {%- if subtitle != blank -%}
      <span class="club-merch__subtitle">{{ subtitle }}</span>
    {%- endif -%}
    {%- if heading != blank -%}
      <h2 class="club-merch__heading">{{ heading }}</h2>
    {%- endif -%}
  </div>

  {%- comment -%} ── Product Grid ── {%- endcomment -%}
  <div class="club-merch__grid">
    {%- if collection != blank -%}
      {%- for product in collection.products limit: max_products -%}
        <div class="club-merch__card">
          {%- comment -%} Image {%- endcomment -%}
          <a href="{{ product.url }}" class="club-merch__img-link">
            <div class="club-merch__img-wrap">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title }}"
                  width="600"
                  height="600"
                  loading="lazy"
                  class="club-merch__img"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'club-merch__placeholder' }}
              {%- endif -%}
            </div>
          </a>

          {%- comment -%} Info {%- endcomment -%}
          <div class="club-merch__info">
            <a href="{{ product.url }}" class="club-merch__title-link">
              <h3 class="club-merch__title">{{ product.title }}</h3>
            </a>
            <span class="club-merch__price">{{ product.price | money }}</span>

            {%- if product.description != blank -%}
              <p class="club-merch__desc">{{ product.description | strip_html | truncate: 100 }}</p>
            {%- endif -%}

            {%- comment -%} Add To Cart {%- endcomment -%}
            <a href="{{ product.url }}" class="club-merch__btn">{{ btn_label }}</a>
          </div>
        </div>
      {%- endfor -%}

    {%- else -%}
      {%- comment -%} Placeholder cards when no collection selected {%- endcomment -%}
      {%- for i in (1..max_products) -%}
        <div class="club-merch__card">
          <div class="club-merch__img-wrap">
            {{ 'product-1' | placeholder_svg_tag: 'club-merch__placeholder' }}
          </div>
          <div class="club-merch__info">
            <h3 class="club-merch__title">Product Name</h3>
            <span class="club-merch__price">$00.00</span>
            <p class="club-merch__desc">Lorem ipsum proin quam nec urna consequat et vel ac sapien orci in sed pote…</p>
            <span class="club-merch__btn">{{ btn_label }}</span>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- comment -%} ── See More ── {%- endcomment -%}
  {%- if collection != blank -%}
    <div class="club-merch__footer">
      <a href="{{ collection.url }}" class="club-merch__see-more">
        {{ see_more_label }}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  {%- endif -%}
</section>

<style>
  @font-face {
    font-family: 'Antonio';
    src: url('{{ "Antonio-Bold.woff2" | asset_url }}') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }
</style>

{% style %}
  /* ═══════════════════════════════════════════
     CLUB MERCHANDISE
  ═══════════════════════════════════════════ */

  #club-merch-{{ section.id }} {
    background: var(--cm-bg, #f5f5f5);
    padding: clamp(2rem, 5vw, 4rem) clamp(1rem, 3vw, 3rem);
  }

  /* ─── Header: subtitle + heading ─── */
  #club-merch-{{ section.id }} .club-merch__header {
    text-align: center;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  #club-merch-{{ section.id }} .club-merch__subtitle {
    display: block;
    font-family: 'Antonio', 'Oswald', sans-serif;
    font-size: clamp(0.9rem, 1.5vw, 1.2rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--cm-text, #1a1a1a);
    margin-bottom: 0.1rem;
  }

  #club-merch-{{ section.id }} .club-merch__heading {
    font-family: 'Antonio', 'Oswald', 'Impact', sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--cm-accent, #8b1a1a);
    margin: 0;
    line-height: 1;
  }

  /* ─── Product Grid ─── */
  #club-merch-{{ section.id }} .club-merch__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.8rem, 1.5vw, 1.2rem);
  }

  /* ─── Product Card ─── */
  #club-merch-{{ section.id }} .club-merch__card {
    background: var(--cm-card, #ffffff);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  #club-merch-{{ section.id }} .club-merch__card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  /* Image */
  #club-merch-{{ section.id }} .club-merch__img-link {
    display: block;
    text-decoration: none;
  }

  #club-merch-{{ section.id }} .club-merch__img-wrap {
    background: #f0f0f0;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 1rem;
  }

  #club-merch-{{ section.id }} .club-merch__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: transform 0.4s ease;
  }

  #club-merch-{{ section.id }} .club-merch__card:hover .club-merch__img {
    transform: scale(1.05);
  }

  #club-merch-{{ section.id }} .club-merch__placeholder {
    width: 60%;
    height: auto;
    opacity: 0.3;
  }

  /* Info */
  #club-merch-{{ section.id }} .club-merch__info {
    padding: clamp(0.8rem, 1.5vw, 1.2rem);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.25rem;
  }

  #club-merch-{{ section.id }} .club-merch__title-link {
    text-decoration: none;
    color: inherit;
  }

  #club-merch-{{ section.id }} .club-merch__title {
    font-family: 'Antonio', 'Oswald', sans-serif;
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--cm-text, #1a1a1a);
    margin: 0;
    line-height: 1.2;
  }

  #club-merch-{{ section.id }} .club-merch__price {
    font-family: 'Antonio', 'Oswald', sans-serif;
    font-size: clamp(0.85rem, 1.2vw, 1rem);
    font-weight: 400;
    color: var(--cm-text, #1a1a1a);
    opacity: 0.7;
  }

  #club-merch-{{ section.id }} .club-merch__desc {
    font-size: clamp(0.75rem, 1vw, 0.85rem);
    line-height: 1.5;
    color: var(--cm-text, #1a1a1a);
    opacity: 0.65;
    margin: 0.3rem 0 0 0;
    flex: 1;
  }

  /* Add To Cart Button */
  #club-merch-{{ section.id }} .club-merch__btn {
    display: inline-block;
    align-self: flex-start;
    margin-top: auto;
    padding: 0.45rem 1.2rem;
    font-family: 'Antonio', 'Oswald', sans-serif;
    font-size: clamp(0.8rem, 1vw, 0.9rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--cm-accent, #8b1a1a);
    border: 2px solid var(--cm-accent, #8b1a1a);
    background: transparent;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease;
    margin-top: 0.6rem;
  }

  #club-merch-{{ section.id }} .club-merch__btn:hover {
    background: var(--cm-accent, #8b1a1a);
    color: #fff;
  }

  /* ─── See More Footer ─── */
  #club-merch-{{ section.id }} .club-merch__footer {
    display: flex;
    justify-content: flex-end;
    margin-top: clamp(1rem, 2vw, 1.5rem);
    padding-right: 0.5rem;
  }

  #club-merch-{{ section.id }} .club-merch__see-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Antonio', 'Oswald', sans-serif;
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--cm-text, #1a1a1a);
    text-decoration: none;
    transition: color 0.3s ease, gap 0.3s ease;
  }

  #club-merch-{{ section.id }} .club-merch__see-more:hover {
    color: var(--cm-accent, #8b1a1a);
    gap: 0.7rem;
  }

  /* ═══════════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════════ */

  @media (max-width: 1024px) {
    #club-merch-{{ section.id }} .club-merch__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    #club-merch-{{ section.id }} .club-merch__grid {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin: 0 auto;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Club Merchandise",
  "tag": "section",
  "class": "club-merch-section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "CLUB"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "MERCHANDISE"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max Products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Card Button Label",
      "default": "Add To Cart"
    },
    {
      "type": "text",
      "id": "see_more_label",
      "label": "See More Label",
      "default": "See More"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#8b1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    }
  ],
  "presets": [
    {
      "name": "Club Merchandise"
    }
  ]
}
{% endschema %}
