{%- comment -%}
  Custom Footer — Park Orchards FC & NC
  Uses Shopify nested blocks for maximum customiser flexibility.
  
  Structure:
    Left:  Logo  ·  Brand name  ·  Social heading + icon links
    Right: Menu columns (nested blocks: column → links)
    Background: dark gradient + optional watermark logo
{%- endcomment -%}

{%- liquid
  assign bg_start  = section.settings.bg_start
  assign bg_end    = section.settings.bg_end
  assign text_col  = section.settings.text_color
  assign accent    = section.settings.accent_color
  assign logo      = section.settings.logo
  assign logo_w    = section.settings.logo_width
  assign brand     = section.settings.brand_name
  assign social_h  = section.settings.social_heading
  assign watermark = section.settings.watermark_image
-%}

<footer
  class="po-footer po-footer--{{ section.id }}"
  style="
    --pof-bg-start: {{ bg_start }};
    --pof-bg-end: {{ bg_end }};
    --pof-text: {{ text_col }};
    --pof-accent: {{ accent }};
    --pof-logo-w: {{ logo_w }}px;
  "
>
  {%- comment -%} Watermark {%- endcomment -%}
  {%- if watermark != blank -%}
    <div class="po-footer__watermark" aria-hidden="true">
      <img
        src="{{ watermark | image_url: width: 600 }}"
        alt=""
        loading="lazy"
        width="600"
        height="600"
      >
    </div>
  {%- endif -%}

  <div class="po-footer__inner{% if section.settings.content_width == 'page' %} page-width{% endif %}">
    {%- comment -%} ═══ LEFT COLUMN ═══ {%- endcomment -%}
    <div class="po-footer__left">
      <div class="po-footer__brand-row">
        {%- if logo != blank -%}
          <div class="po-footer__logo-wrap">
            {%- assign logo_w_2x = logo_w | times: 2 -%}
            <img
              class="po-footer__logo"
              src="{{ logo | image_url: width: logo_w_2x }}"
              alt="{{ brand | escape }}"
              width="{{ logo_w }}"
              height="auto"
              loading="lazy"
            >
          </div>
        {%- endif -%}

        {%- if brand != blank -%}
          <div class="po-footer__brand">{{ brand }}</div>
        {%- endif -%}
      </div>

      {%- if social_h != blank -%}
        <div class="po-footer__social-heading">{{ social_h }}</div>
      {%- endif -%}

      <div class="po-footer__socials">
        {%- if section.settings.social_facebook != blank -%}
          <a href="{{ section.settings.social_facebook }}" class="po-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_linkedin != blank -%}
          <a href="{{ section.settings.social_linkedin }}" class="po-footer__social-link" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_instagram != blank -%}
          <a href="{{ section.settings.social_instagram }}" class="po-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_youtube != blank -%}
          <a href="{{ section.settings.social_youtube }}" class="po-footer__social-link" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_tiktok != blank -%}
          <a href="{{ section.settings.social_tiktok }}" class="po-footer__social-link" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ═══ RIGHT — MENU COLUMNS (flat blocks with link_list) ═══ {%- endcomment -%}
    <div class="po-footer__right">
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu_column' -%}
          <div class="po-footer__menu-col" {{ block.shopify_attributes }}>
            {%- if block.settings.menu_title != blank -%}
              <h4 class="po-footer__menu-title">{{ block.settings.menu_title }}</h4>
            {%- endif -%}

            {%- if block.settings.menu_handle != blank -%}
              <ul class="po-footer__menu-list">
                {%- for link in linklists[block.settings.menu_handle].links -%}
                  <li>
                    <a href="{{ link.url }}" class="po-footer__menu-link">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} ═══ BOTTOM BAR ═══ {%- endcomment -%}
  {%- if section.settings.show_bottom_bar -%}
    <div class="po-footer__bottom page-width">
      <span class="po-footer__copy">{{ section.settings.copyright }}</span>
    </div>
  {%- endif -%}
</footer>

{% style %}
  /* ═══════════════════════════════════════════
     CUSTOM FOOTER
  ═══════════════════════════════════════════ */
  .po-footer--{{ section.id }} {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--pof-bg-start) 0%, var(--pof-bg-end) 100%);
    color: var(--pof-text);
    padding: clamp(2.5rem, 5vw, 4rem) 0 0;
    font-family: 'Antonio', 'Oswald', sans-serif;
  }

  /* ─── Watermark ─── */
  .po-footer--{{ section.id }} .po-footer__watermark {
    position: absolute;
    right: -60px;
    bottom: -40px;
    width: clamp(250px, 30vw, 420px);
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
  }
  .po-footer--{{ section.id }} .po-footer__watermark img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ─── Inner layout ─── */
  .po-footer--{{ section.id }} .po-footer__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  /* ─── Left column ─── */
  .po-footer--{{ section.id }} .po-footer__left {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .po-footer--{{ section.id }} .po-footer__brand-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }
  .po-footer--{{ section.id }} .po-footer__logo-wrap {
    flex-shrink: 0;
  }
  .po-footer--{{ section.id }} .po-footer__logo {
    width: var(--pof-logo-w, 80px);
    height: auto;
    display: block;
  }
  .po-footer--{{ section.id }} .po-footer__brand {
    font-weight: 800;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .po-footer--{{ section.id }} .po-footer__social-heading {
    font-weight: 700;
    font-size: clamp(0.8rem, 1.1vw, 0.95rem);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.85;
    margin-bottom: 0.5rem;
    font-style: italic;
  }
  .po-footer--{{ section.id }} .po-footer__socials {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .po-footer--{{ section.id }} .po-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    color: var(--pof-text);
    transition: background 0.3s, transform 0.3s;
  }
  .po-footer--{{ section.id }} .po-footer__social-link:hover {
    background: var(--pof-accent);
    transform: scale(1.1);
  }
  .po-footer--{{ section.id }} .po-footer__social-link svg {
    width: 18px;
    height: 18px;
  }

  /* ─── Right — menus ─── */
  .po-footer--{{ section.id }} .po-footer__right {
    display: flex;
    gap: clamp(1.5rem, 3vw, 3rem);
    flex-wrap: wrap;
  }
  .po-footer--{{ section.id }} .po-footer__menu-col {
    min-width: 140px;
    flex: 1;
  }
  .po-footer--{{ section.id }} .po-footer__menu-title {
    font-weight: 800;
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.8rem;
    color: var(--pof-text);
  }
  .po-footer--{{ section.id }} .po-footer__menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .po-footer--{{ section.id }} .po-footer__menu-link {
    color: var(--pof-text);
    opacity: 0.75;
    text-decoration: none;
    font-size: clamp(0.82rem, 1.1vw, 0.95rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    transition: opacity 0.3s;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .po-footer--{{ section.id }} .po-footer__menu-link:hover {
    opacity: 1;
  }

  /* ─── Bottom bar ─── */
  .po-footer--{{ section.id }} .po-footer__bottom {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    padding: 1rem 0;
    text-align: center;
  }
  .po-footer--{{ section.id }} .po-footer__copy {
    font-size: 0.78rem;
    opacity: 0.5;
    letter-spacing: 0.02em;
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 768px) {
    .po-footer--{{ section.id }} .po-footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .po-footer--{{ section.id }} .po-footer__left {
      align-items: center;
      text-align: center;
    }
    .po-footer--{{ section.id }} .po-footer__socials {
      justify-content: center;
    }
    .po-footer--{{ section.id }} .po-footer__right {
      justify-content: center;
      text-align: center;
    }
    .po-footer--{{ section.id }} .po-footer__menu-col {
      min-width: 120px;
      flex: 0 0 auto;
    }
    .po-footer--{{ section.id }} .po-footer__watermark {
      right: -80px;
      bottom: -60px;
      opacity: 0.05;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Custom Footer",
  "tag": "section",
  "class": "po-footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 40,
      "max": 200,
      "step": 5,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "Park Orchards Football Netball Club"
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Social heading",
      "default": "Follow the Sharks"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_linkedin",
      "label": "LinkedIn URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "page",
      "options": [
        { "value": "page", "label": "Page width" },
        { "value": "full", "label": "Full width" }
      ]
    },
    {
      "type": "color",
      "id": "bg_start",
      "label": "Background start",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "bg_end",
      "label": "Background end",
      "default": "#4a0e0e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / hover color",
      "default": "#b0121b"
    },
    {
      "type": "image_picker",
      "id": "watermark_image",
      "label": "Watermark image (bottom-right)"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "checkbox",
      "id": "show_bottom_bar",
      "label": "Show bottom bar",
      "default": true
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 Park Orchards Football & Netball Club. All rights reserved."
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "menu_title",
          "label": "Column title",
          "default": "Menu"
        },
        {
          "type": "link_list",
          "id": "menu_handle",
          "label": "Menu",
          "info": "Create menus in Online Store → Navigation, then select here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer",
      "blocks": [
        { "type": "menu_column", "settings": { "menu_title": "The Club" } },
        { "type": "menu_column", "settings": { "menu_title": "Sponsors" } },
        { "type": "menu_column", "settings": { "menu_title": "Links" } }
      ]
    }
  ]
}
{% endschema %}
