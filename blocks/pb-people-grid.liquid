{%- comment -%}
  PB People Grid — Theme block
  Queries club_person metaobjects filtered by any club_people_group handle
  Use group handle setting to pick which group to display (or 'all' for everyone)
{%- endcomment -%}

{%- liquid
  assign group_handle   = block.settings.group_handle     | default: 'foundation-members'
  assign heading        = block.settings.heading
  assign subtitle       = block.settings.subtitle
  assign show_photo     = block.settings.show_photo
  assign show_role      = block.settings.show_role
  assign cols_d         = block.settings.columns_desktop | default: 4
  assign cols_t         = block.settings.columns_tablet  | default: 3
  assign cols_m         = block.settings.columns_mobile  | default: 2
  assign accent         = block.settings.accent_color    | default: '#c0182d'
  assign heading_color  = block.settings.heading_color   | default: '#1a1a1a'
  assign name_color     = block.settings.name_color      | default: '#1a1a1a'
  assign role_color     = block.settings.role_color       | default: '#777777'
  assign card_bg        = block.settings.card_bg          | default: '#ffffff'
  assign card_border    = block.settings.card_border      | default: '#eeeeee'
  assign card_radius    = block.settings.card_radius      | default: 16
  assign card_shadow    = block.settings.card_shadow
  assign max_w          = block.settings.max_width        | default: 1200
  assign photo_style    = block.settings.photo_style      | default: 'circle'
  assign show_all       = false

  if group_handle == 'all'
    assign show_all = true
  endif

  assign all_people = shop.metaobjects.club_person.values
-%}

<div
  class="pb-fm pb-fm-{{ block.id }}"
  style="
    --fm-accent: {{ accent }};
    --fm-accent-rgb: {{ accent | color_to_rgb | remove: 'rgb(' | remove: ')' }};
    --fm-heading: {{ heading_color }};
    --fm-name: {{ name_color }};
    --fm-role: {{ role_color }};
    --fm-card-bg: {{ card_bg }};
    --fm-card-border: {{ card_border }};
    --fm-card-radius: {{ card_radius }}px;
    --fm-cols-d: {{ cols_d }};
    --fm-cols-t: {{ cols_t }};
    --fm-cols-m: {{ cols_m }};
    --fm-max-w: {{ max_w }}px;
  "
  {{ block.shopify_attributes }}
>
  {%- comment -%} Header {%- endcomment -%}
  {%- if heading != blank or subtitle != blank -%}
    <div class="pb-fm__header">
      {%- if subtitle != blank -%}
        <span class="pb-fm__subtitle">{{ subtitle }}</span>
      {%- endif -%}
      {%- if heading != blank -%}
        <h2 class="pb-fm__heading">{{ heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} Grid {%- endcomment -%}
  <div class="pb-fm__grid">
    {%- for person in all_people -%}
      {%- assign person_group = person.group.value -%}
      {%- assign person_group_handle = person_group.handle | default: person_group.system.handle -%}
      {%- if show_all or person_group_handle == group_handle -%}

        {%- assign p_name  = person.full_name.value  | default: '' -%}
        {%- assign p_role  = person.role_title.value  | default: '' -%}
        {%- assign p_phone = person.phone.value        | default: '' -%}
        {%- assign p_email = person.email.value        | default: '' -%}

        <div
          class="pb-fm__card{% if card_shadow %} pb-fm__card--shadow{% endif %}"
          data-name="{{ p_name | escape }}"
          data-role="{{ p_role | escape }}"
          data-phone="{{ p_phone | escape }}"
          data-email="{{ p_email | escape }}"
          data-org="Park Orchards Football &amp; Netball Club"
        >

          {%- comment -%} Photo {%- endcomment -%}
          {%- if show_photo -%}
            <div class="pb-fm__photo-wrap pb-fm__photo--{{ photo_style }}">
              {%- if person.photo.value != blank -%}
                <img
                  src="{{ person.photo.value | image_url: width: 300, height: 300, crop: 'center' }}"
                  alt="{{ p_name }}"
                  width="300" height="300"
                  loading="lazy"
                >
              {%- else -%}
                <div class="pb-fm__photo-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- comment -%} Info {%- endcomment -%}
          <div class="pb-fm__body">
            <div class="pb-fm__identity">
              <h3 class="pb-fm__name">{{ p_name }}</h3>
              {%- if show_role and p_role != blank -%}
                <span class="pb-fm__role">{{ p_role }}</span>
              {%- endif -%}
            </div>

            {%- if p_phone != blank or p_email != blank -%}
              <ul class="pb-fm__contacts">
                {%- if p_phone != blank -%}
                  <li class="pb-fm__contact">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.44 2 2 0 0 1 3.6 1.25h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.85a16 16 0 0 0 6.06 6.06l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                    <a href="tel:{{ p_phone | remove: ' ' }}">{{ p_phone }}</a>
                  </li>
                {%- endif -%}
                {%- if p_email != blank -%}
                  <li class="pb-fm__contact">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                      <polyline points="22,6 12,13 2,6"/>
                    </svg>
                    <a href="mailto:{{ p_email }}">{{ p_email }}</a>
                  </li>
                {%- endif -%}
              </ul>
            {%- endif -%}

            {%- comment -%} vCard button {%- endcomment -%}
            <button
              class="pb-fm__vcard-btn"
              type="button"
              aria-label="Save contact for {{ p_name }}"
              onclick="pbVcardDownload(this)"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="8.5" cy="7" r="4"/>
                <line x1="20" y1="8" x2="20" y2="14"/>
                <line x1="23" y1="11" x2="17" y2="11"/>
              </svg>
              Save Contact
            </button>
          </div>

        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
  /* ═══════════════════════════════════════════
     PB PEOPLE GRID — Theme block
  ═══════════════════════════════════════════ */

  .pb-fm-{{ block.id }} {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    max-width: var(--fm-max-w, 1200px);
    margin: 0 auto;
  }

  /* ─── Header ─── */
  .pb-fm-{{ block.id }} .pb-fm__header {
    text-align: center;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .pb-fm-{{ block.id }} .pb-fm__subtitle {
    display: inline-block;
    font-weight: 600;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--fm-accent);
    padding: 0.3rem 0.9rem;
    border: 1px solid rgba(var(--fm-accent-rgb), 0.25);
    border-radius: 100px;
    background: rgba(var(--fm-accent-rgb), 0.06);
    margin-bottom: 0.75rem;
  }

  .pb-fm-{{ block.id }} .pb-fm__heading {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--fm-heading, #1a1a1a);
    margin: 0;
    line-height: 1.15;
  }

  /* ─── Grid ─── */
  .pb-fm-{{ block.id }} .pb-fm__grid {
    display: grid;
    grid-template-columns: repeat(var(--fm-cols-m, 2), 1fr);
    gap: clamp(0.75rem, 2vw, 1.25rem);
  }

  @media (min-width: 750px) {
    .pb-fm-{{ block.id }} .pb-fm__grid {
      grid-template-columns: repeat(var(--fm-cols-t, 3), 1fr);
    }
  }

  @media (min-width: 990px) {
    .pb-fm-{{ block.id }} .pb-fm__grid {
      grid-template-columns: repeat(var(--fm-cols-d, 4), 1fr);
    }
  }

  /* ─── Card ─── */
  .pb-fm-{{ block.id }} .pb-fm__card {
    background: var(--fm-card-bg, #fff);
    border: 1px solid var(--fm-card-border, #eee);
    border-radius: var(--fm-card-radius, 16px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    padding: clamp(1.25rem, 2.5vw, 1.75rem) clamp(1rem, 2vw, 1.5rem);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.3s ease,
                box-shadow 0.35s ease;
  }

  .pb-fm-{{ block.id }} .pb-fm__card:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--fm-accent-rgb), 0.3);
  }

  .pb-fm-{{ block.id }} .pb-fm__card--shadow {
    box-shadow: 0 2px 12px -2px rgba(0, 0, 0, 0.06);
  }
  .pb-fm-{{ block.id }} .pb-fm__card--shadow:hover {
    box-shadow: 0 12px 36px -8px rgba(0, 0, 0, 0.1),
                0 0 20px -6px rgba(var(--fm-accent-rgb), 0.08);
  }

  /* ─── Photo ─── */
  .pb-fm-{{ block.id }} .pb-fm__photo-wrap {
    width: 80px;
    height: 80px;
    margin-bottom: 1rem;
    overflow: hidden;
    flex-shrink: 0;
    align-self: center;
  }

  .pb-fm-{{ block.id }} .pb-fm__photo--circle  { border-radius: 50%; }
  .pb-fm-{{ block.id }} .pb-fm__photo--rounded { border-radius: 12px; }
  .pb-fm-{{ block.id }} .pb-fm__photo--square  { border-radius: 4px; }

  .pb-fm-{{ block.id }} .pb-fm__photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pb-fm-{{ block.id }} .pb-fm__photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--fm-accent-rgb), 0.06);
    color: rgba(var(--fm-accent-rgb), 0.4);
    border: 1px solid rgba(var(--fm-accent-rgb), 0.1);
    border-radius: inherit;
  }

  /* ─── Body ─── */
  .pb-fm-{{ block.id }} .pb-fm__body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    width: 100%;
  }

  /* ─── Identity ─── */
  .pb-fm-{{ block.id }} .pb-fm__identity {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .pb-fm-{{ block.id }} .pb-fm__name {
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--fm-name, #1a1a1a);
    margin: 0;
    line-height: 1.25;
  }

  .pb-fm-{{ block.id }} .pb-fm__role {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fm-name, #1a1a1a);
    opacity: 0.7;
  }

  /* ─── Contact list ─── */
  .pb-fm-{{ block.id }} .pb-fm__contacts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .pb-fm-{{ block.id }} .pb-fm__contact {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .pb-fm-{{ block.id }} .pb-fm__contact svg {
    color: var(--fm-role, #777);
    flex-shrink: 0;
  }

  .pb-fm-{{ block.id }} .pb-fm__contact a {
    font-size: 0.72rem;
    color: var(--fm-role, #555);
    text-decoration: none;
    word-break: break-all;
    transition: color 0.2s ease;
  }

  .pb-fm-{{ block.id }} .pb-fm__contact a:hover {
    color: var(--fm-accent);
  }

  /* ─── Divider ─── */
  .pb-fm-{{ block.id }} .pb-fm__contacts:not(:empty)::before {
    content: '';
    display: block;
    height: 1px;
    background: var(--fm-card-border, #eee);
    margin-bottom: 0.3rem;
  }

  /* ─── vCard button ─── */
  .pb-fm-{{ block.id }} .pb-fm__vcard-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.25rem;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fm-accent);
    transition: opacity 0.2s ease, gap 0.2s ease;
  }

  .pb-fm-{{ block.id }} .pb-fm__vcard-btn:hover {
    opacity: 0.75;
    gap: 0.6rem;
  }

  /* ─── Responsive ─── */
  @media (max-width: 480px) {
    .pb-fm-{{ block.id }} .pb-fm__photo-wrap {
      width: 64px;
      height: 64px;
    }
    .pb-fm-{{ block.id }} .pb-fm__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  if (!window.pbVcardDownload) {
    window.pbVcardDownload = function(btn) {
      var card = btn.closest('[data-name]');
      var name  = card.dataset.name  || '';
      var role  = card.dataset.role  || '';
      var phone = card.dataset.phone || '';
      var email = card.dataset.email || '';
      var org   = card.dataset.org   || '';

      var lines = [
        'BEGIN:VCARD',
        'VERSION:3.0',
        'FN:' + name,
        'N:' + name.split(' ').reverse().join(';') + ';;;',
        role  ? 'TITLE:' + role  : null,
        org   ? 'ORG:' + org     : null,
        phone ? 'TEL;TYPE=CELL:' + phone : null,
        email ? 'EMAIL;TYPE=INTERNET:' + email : null,
        'END:VCARD'
      ].filter(Boolean).join('\r\n');

      var blob = new Blob([lines], { type: 'text/vcard;charset=utf-8' });
      var url  = URL.createObjectURL(blob);
      var a    = document.createElement('a');
      a.href     = url;
      a.download = name.toLowerCase().replace(/\s+/g, '-') + '.vcf';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    };
  }
</script>

{% schema %}
{
  "name": "PB People Grid",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "── Data Source ──"
    },
    {
      "type": "text",
      "id": "group_handle",
      "label": "Group handle",
      "default": "foundation-members",
      "info": "Enter the club_people_group handle to filter. Use 'all' to show everyone. Common handles: committee-personnel, support-personnel, volunteers, community-members, foundation-members"
    },

    {
      "type": "header",
      "content": "── Content ──"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle tag",
      "default": "Our Legacy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Foundation Members"
    },

    {
      "type": "header",
      "content": "── Display ──"
    },
    {
      "type": "checkbox",
      "id": "show_photo",
      "label": "Show photo",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_role",
      "label": "Show role title",
      "default": true
    },
    {
      "type": "select",
      "id": "photo_style",
      "label": "Photo shape",
      "default": "circle",
      "options": [
        { "value": "circle", "label": "Circle" },
        { "value": "rounded", "label": "Rounded" },
        { "value": "square", "label": "Square" }
      ]
    },

    {
      "type": "header",
      "content": "── Layout ──"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 600,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 1200
    },

    {
      "type": "header",
      "content": "── Colors ──"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#c0182d"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Name color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "role_color",
      "label": "Role color",
      "default": "#777777"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#eeeeee"
    },

    {
      "type": "header",
      "content": "── Card Style ──"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "card_shadow",
      "label": "Card shadow",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "People Grid"
    }
  ]
}
{% endschema %}
